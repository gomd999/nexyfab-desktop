# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# tauri
/src-tauri/target/
/src-tauri/gen/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# admin settings
admin-settings.json

# playwright
/playwright-report/
/test-results/

# large binary / archive files
*.db
*.zip
*.wasm
/out2/
/data/

# Tauri signing keys (NEVER commit)
/.tauri-keys/

# Tauri build artifacts
/src-tauri/target/

# Desktop installers — hosted on GitHub Releases (gomd999/nexyfab-desktop)
/public/releases/
