{
  "name": "nexyfab-frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "prebuild": "node -e \"const fs=require('fs');fs.copyFileSync('node_modules/occt-import-js/dist/occt-import-js.wasm','public/occt-import-js.wasm');console.log('✓ occt-import-js.wasm copied to public/')\"",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "dev:tauri": "next dev --port 3000",
    "build:tauri": "node scripts/tauri-build.mjs",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "tauri:release": "bash scripts/tauri-release.sh --build",
    "tauri:gen-keys": "bash scripts/tauri-release.sh --gen-keys",
    "tauri:env": "bash scripts/tauri-release.sh --env",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "migrate": "tsx scripts/migrate.ts",
    "backup": "tsx scripts/backup.ts",
    "backup:list": "tsx scripts/backup.ts --list"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1025.0",
