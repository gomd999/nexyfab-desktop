# ════════════════════════════════════════════════════════════════════════════
# NexyFab 환경변수 템플릿 — 이 파일을 .env.local로 복사 후 실제 값으로 교체
# 절대 실제 시크릿을 이 파일에 입력하지 마세요
# ════════════════════════════════════════════════════════════════════════════

# ── 앱 URL ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://nexyfab.com
NEXT_PUBLIC_SITE_URL=https://nexyfab.com
# SSO/Auth server (Cloudflare Workers) — login/register/reset 리다이렉트 베이스
NEXT_PUBLIC_AUTH_URL=https://auth.nexysys.com
# 상위 Nexysys 포털 (헤더/푸터 링크, forgot-password 등)
NEXT_PUBLIC_NEXYSYS_URL=https://nexysys.com
# 한국어(/kr) 푸터의 「통합 사업자·법적 고지」 링크 목적지 (미설정 시 {NEXYSYS_URL}/kr/ )
# NEXT_PUBLIC_NEXYSYS_LEGAL_URL=https://nexysys.com/kr/legal

# 고객 문의 이메일 — 푸터 mailto·환불 안내 페이지 (미설정 시 support@nexyfab.com)
# NEXT_PUBLIC_SUPPORT_EMAIL=support@nexyfab.com

# ── 필수 보안 ───────────────────────────────────────────────────────────────
# 최소 32자 랜덤: openssl rand -base64 32
JWT_SECRET=CHANGE_ME_MIN_32_CHARS
# bcrypt 해시: node -e "require('bcryptjs').hash('yourpassword',12).then(console.log)"
ADMIN_PASSWORD_HASH=CHANGE_ME_BCRYPT_HASH
ADMIN_SECRET=CHANGE_ME_MIN_16_CHARS

# ── 데이터베이스 ─────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/nexyfab?sslmode=require

# ── Redis (프로덕션 필수) ────────────────────────────────────────────────────
REDIS_URL=rediss://user:password@host:port

# ── 이메일 발송 (Resend 권장, 또는 SMTP) ─────────────────────────────────────
# 방법 1: Resend (https://resend.com) — RESEND_API_KEY만 설정하면 즉시 동작
RESEND_API_KEY=re_CHANGE_ME

# 방법 2: SMTP 직접 연결 (Resend 없을 때 폴백)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=nexyfab@nexysys.com
SMTP_PASS=CHANGE_ME

# NexyFab 공식 발신 주소 — 모든 이메일이 이 주소로 발송됨
SMTP_FROM="NexyFab" <nexyfab@nexysys.com>
NEXYFAB_FROM_EMAIL=nexyfab@nexysys.com

# 관리자 수신 주소
ADMIN_EMAIL=nexyfab@nexysys.com
NEXYFAB_ADMIN_EMAIL=nexyfab@nexysys.com
# 주문/문의 알림 수신자 (콤마 구분)
SEND_MAIL_RECIPIENTS=nexyfab@nexysys.com

# ── Stripe (글로벌 결제 — 카드) ──────────────────────────────────────────────
# Stripe Dashboard → Developers → API Keys
STRIPE_SECRET_KEY=sk_live_CHANGE_ME
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_CHANGE_ME
# Stripe Dashboard → Developers → Webhooks → 엔드포인트 → Signing secret
# 웹훅 URL: https://nexyfab.com/api/stripe/webhook
STRIPE_WEBHOOK_SECRET=whsec_CHANGE_ME

# ── Airwallex (글로벌 결제) ───────────────────────────────────────────────────
AIRWALLEX_CLIENT_ID=CHANGE_ME
AIRWALLEX_API_KEY=CHANGE_ME
AIRWALLEX_WEBHOOK_SECRET=CHANGE_ME
# 환경: "prod" = 운영, 그 외 = sandbox (demo)
AIRWALLEX_ENV=demo
# 국가별 기본 결제수단 오버라이드 (콤마 구분 awMethod 코드, 선택)
# AIRWALLEX_DEFAULT_PM=card,wechatpay
# 플랜별 Airwallex 가격 오버라이드 (USD 기준, 미설정 시 country-pricing.ts 기본값 사용)
# AIRWALLEX_PLAN_PRO_USD=29
# AIRWALLEX_PLAN_TEAM_USD=79
# AIRWALLEX_PLAN_ENTERPRISE_USD=299

# ── Toss Payments ────────────────────────────────────────────────────────────
NEXT_PUBLIC_TOSS_CLIENT_KEY=CHANGE_ME
TOSS_SECRET_KEY=CHANGE_ME
# 웹훅 서명 검증용 (Toss Payments 대시보드 → 웹훅 → 서명 키) — 미설정 시 웹훅 거부
TOSS_WEBHOOK_SECRET=CHANGE_ME

# ── AI API ────────────────────────────────────────────────────────────────────
DEEPSEEK_API_KEY=CHANGE_ME
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
QWEN_API_KEY=CHANGE_ME
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ── reCAPTCHA v3 ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=CHANGE_ME
RECAPTCHA_SECRET_KEY=CHANGE_ME

# ── 외부 API ──────────────────────────────────────────────────────────────────
ALPHAVANTAGE_API_KEY=CHANGE_ME

# ── 파일 스토리지 (Cloudflare R2) ────────────────────────────────────────────
# R2 endpoint: https://<account_id>.r2.cloudflarestorage.com
S3_ENDPOINT=CHANGE_ME
S3_BUCKET=nexyfab
S3_REGION=auto
S3_ACCESS_KEY_ID=CHANGE_ME
S3_SECRET_ACCESS_KEY=CHANGE_ME
# 퍼블릭 버킷 URL (선택 — 미설정 시 signed URL 사용)
# S3_PUBLIC_URL=https://pub-xxx.r2.dev

# ── CORS (외부 도메인 허용 시 콤마 구분) ────────────────────────────────────
# CORS_ALLOWED_ORIGINS=https://partner.example.com,https://app.example.com

# ── Cron ─────────────────────────────────────────────────────────────────────
# POST /api/jobs/process 호출 시 필요 (Railway/Vercel Cron)
# openssl rand -hex 32
CRON_SECRET=CHANGE_ME

# ── 모니터링 (Sentry) ─────────────────────────────────────────────────────────
# DSN은 Sentry 프로젝트 Settings → Client Keys에서 확인
NEXT_PUBLIC_SENTRY_DSN=CHANGE_ME
SENTRY_DSN=CHANGE_ME
SENTRY_ORG=CHANGE_ME
SENTRY_PROJECT=nexyfab-web
SENTRY_AUTH_TOKEN=CHANGE_ME
# 브라우저 SDK: instrumentation-client.ts — 미설정·CHANGE_ME 이면 Sentry 미초기화
NEXT_PUBLIC_RELEASE=
# NEXT_PUBLIC_VERCEL_ENV=production
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1
NEXT_PUBLIC_SENTRY_REPLAY_ON_ERROR_SAMPLE_RATE=1
NEXT_PUBLIC_SENTRY_REPLAY_SESSION_SAMPLE_RATE=0.01

# ── Tauri 데스크톱 자동 업데이트 (선택) ───────────────────────────────────────
# npm run tauri:gen-keys 후 공개 키를 여기 넣고 CI에서만 주입 → scripts/tauri-updater-merge.mjs
# 기본 tauri.conf.json 은 updater.active=false (로컬 빌드용)
# TAURI_UPDATER_PUBKEY=

# ── Nexysys SSO ──────────────────────────────────────────────────────────────
NEXYSYS_AUTH_URL=https://auth.nexysys.com

# ── Railway Volume (DB 영속성) ───────────────────────────────────────────────
# Railway Volume을 /data에 마운트 후 설정 (Railway Dashboard → Add Volume → Mount: /data)
# DATA_ROOT=/data
# 또는 직접 경로 지정:
# NEXYFAB_DB_PATH=/data/nexyfab.db
