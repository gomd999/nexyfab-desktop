{
  "productName": "NexyFab",
  "version": "0.1.0",
  "identifier": "com.nexysys.nexyfab",
  "build": {
    "frontendDist": "../out",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm run dev:tauri",
    "beforeBuildCommand": "npm run build:tauri"
  },
  "app": {
    "windows": [
      {
        "title": "NexyFab",
        "width": 1400,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 680,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "dmg", "appimage"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "windows": {
      "wix": {
        "language": "ko-KR"
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDVGOEM2QzM4RjFCNkEyMQpSV1FoYWh1UHc4YjRCWC9jZW5EdnY4U0p6a3hjMGNaTmhscWs1UDJ5YitESGtXbFJvUUpwSWZ2Wgo=",
      "endpoints": [
        "https://nexyfab.com/api/desktop-update/{{target}}/{{arch}}/{{current_version}}"
      ],
      "dialog": true
    }
  }
}
